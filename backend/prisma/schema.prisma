// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum JobStatus {
  QUEUED
  SCHEDULED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
  DEAD
}

enum JobType {
  IMMEDIATE
  DELAYED
  CRON
  RECURRING
  BATCH
}

enum WorkerStatus {
  ONLINE
  IDLE
  BUSY
  DRAINING
  OFFLINE
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

enum QueueStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

// ─────────────────────────────────────────────
// USER / AUTH
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         UserRole @default(MEMBER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  refreshTokens RefreshToken[]
  orgMemberships OrgMember[]
  projectMemberships ProjectMember[]
  createdJobs   Job[]    @relation("JobCreator")
  auditLogs     AuditLog[]

  @@map("users")
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────
// ORGANIZATION
// ─────────────────────────────────────────────

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members  OrgMember[]
  projects Project[]

  @@map("organizations")
  @@index([slug])
}

model OrgMember {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  role      OrgRole  @default(MEMBER)
  joinedAt  DateTime @default(now()) @map("joined_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
  @@index([orgId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────

model Project {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  slug        String
  description String?
  apiKey      String   @unique @map("api_key") @default(uuid())
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members      ProjectMember[]
  queues       Queue[]

  @@unique([orgId, slug])
  @@map("projects")
  @@index([orgId])
  @@index([apiKey])
}

model ProjectMember {
  id        String  @id @default(uuid())
  projectId String  @map("project_id")
  userId    String  @map("user_id")
  role      OrgRole @default(MEMBER)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
  @@index([projectId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// QUEUE
// ─────────────────────────────────────────────

model Queue {
  id             String      @id @default(uuid())
  projectId      String      @map("project_id")
  name           String
  description    String?
  status         QueueStatus @default(ACTIVE)
  priority       Int         @default(5)
  maxConcurrency Int         @default(5) @map("max_concurrency")
  rateLimitCount Int?        @map("rate_limit_count")
  rateLimitWindow Int?       @map("rate_limit_window")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  jobs        Job[]
  retryPolicy RetryPolicy?
  metrics     QueueMetric[]

  @@unique([projectId, name])
  @@map("queues")
  @@index([projectId])
  @@index([status])
}

model RetryPolicy {
  id              String        @id @default(uuid())
  queueId         String        @unique @map("queue_id")
  maxRetries      Int           @default(3) @map("max_retries")
  strategy        RetryStrategy @default(EXPONENTIAL)
  initialDelay    Int           @default(1000) @map("initial_delay")
  maxDelay        Int           @default(30000) @map("max_delay")
  backoffMultiple Float         @default(2.0) @map("backoff_multiple")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  queue Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@map("retry_policies")
}

model QueueMetric {
  id            String   @id @default(uuid())
  queueId       String   @map("queue_id")
  totalJobs     Int      @default(0) @map("total_jobs")
  completedJobs Int      @default(0) @map("completed_jobs")
  failedJobs    Int      @default(0) @map("failed_jobs")
  pendingJobs   Int      @default(0) @map("pending_jobs")
  runningJobs   Int      @default(0) @map("running_jobs")
  avgDuration   Float    @default(0) @map("avg_duration")
  throughput    Float    @default(0)
  recordedAt    DateTime @default(now()) @map("recorded_at")

  queue Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@map("queue_metrics")
  @@index([queueId])
  @@index([recordedAt])
}

// ─────────────────────────────────────────────
// JOB
// ─────────────────────────────────────────────

model Job {
  id              String    @id @default(uuid())
  queueId         String    @map("queue_id")
  createdById     String?   @map("created_by_id")
  name            String
  type            JobType   @default(IMMEDIATE)
  status          JobStatus @default(QUEUED)
  priority        Int       @default(5)
  payload         Json      @default("{}")
  headers         Json      @default("{}")
  tags            String[]  @default([])
  cronExpression  String?   @map("cron_expression")
  scheduledAt     DateTime? @map("scheduled_at")
  runAt           DateTime? @map("run_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  failedAt        DateTime? @map("failed_at")
  retryCount      Int       @default(0) @map("retry_count")
  maxRetries      Int       @default(3) @map("max_retries")
  timeout         Int       @default(30000)
  result          Json?
  errorMessage    String?   @map("error_message")
  errorStack      String?   @map("error_stack")
  workerId        String?   @map("worker_id")
  batchId         String?   @map("batch_id")
  parentJobId     String?   @map("parent_job_id")
  idempotencyKey  String?   @unique @map("idempotency_key")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  queue      Queue        @relation(fields: [queueId], references: [id], onDelete: Cascade)
  createdBy  User?        @relation("JobCreator", fields: [createdById], references: [id])
  worker     Worker?      @relation(fields: [workerId], references: [id])
  executions JobExecution[]
  logs       JobLog[]
  deadLetter DeadLetterQueue?
  parentJob  Job?         @relation("JobDependency", fields: [parentJobId], references: [id])
  childJobs  Job[]        @relation("JobDependency")

  @@map("jobs")
  @@index([queueId])
  @@index([status])
  @@index([type])
  @@index([scheduledAt])
  @@index([workerId])
  @@index([batchId])
  @@index([createdAt])
  @@index([priority])
}

model JobExecution {
  id         String    @id @default(uuid())
  jobId      String    @map("job_id")
  workerId   String?   @map("worker_id")
  attempt    Int       @default(1)
  startedAt  DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  duration   Int?
  status     JobStatus @default(RUNNING)
  result     Json?
  error      String?

  job    Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker Worker? @relation(fields: [workerId], references: [id])

  @@map("job_executions")
  @@index([jobId])
  @@index([workerId])
  @@index([startedAt])
}

model JobLog {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  level     String   @default("info")
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_logs")
  @@index([jobId])
  @@index([createdAt])
  @@index([level])
}

// ─────────────────────────────────────────────
// SCHEDULED JOBS
// ─────────────────────────────────────────────

model ScheduledJob {
  id             String    @id @default(uuid())
  queueId        String    @map("queue_id")
  name           String
  cronExpression String    @map("cron_expression")
  payload        Json      @default("{}")
  headers        Json      @default("{}")
  tags           String[]  @default([])
  priority       Int       @default(5)
  maxRetries     Int       @default(3) @map("max_retries")
  timeout        Int       @default(30000)
  isActive       Boolean   @default(true) @map("is_active")
  lastRunAt      DateTime? @map("last_run_at")
  nextRunAt      DateTime? @map("next_run_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("scheduled_jobs")
  @@index([queueId])
  @@index([isActive])
  @@index([nextRunAt])
}

// ─────────────────────────────────────────────
// DEAD LETTER QUEUE
// ─────────────────────────────────────────────

model DeadLetterQueue {
  id           String   @id @default(uuid())
  jobId        String   @unique @map("job_id")
  queueId      String   @map("queue_id")
  reason       String
  payload      Json
  errorMessage String?  @map("error_message")
  retryCount   Int      @default(0) @map("retry_count")
  requeued     Boolean  @default(false)
  requeuedAt   DateTime? @map("requeued_at")
  createdAt    DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("dead_letter_queue")
  @@index([queueId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// WORKER
// ─────────────────────────────────────────────

model Worker {
  id           String       @id @default(uuid())
  name         String
  hostname     String
  pid          Int
  queues       String[]
  status       WorkerStatus @default(ONLINE)
  concurrency  Int          @default(5)
  lastHeartbeat DateTime    @map("last_heartbeat")
  startedAt    DateTime     @default(now()) @map("started_at")
  stoppedAt    DateTime?    @map("stopped_at")
  metadata     Json         @default("{}")

  jobs       Job[]
  executions JobExecution[]
  heartbeats WorkerHeartbeat[]

  @@map("workers")
  @@index([status])
  @@index([lastHeartbeat])
}

model WorkerHeartbeat {
  id          String   @id @default(uuid())
  workerId    String   @map("worker_id")
  activeJobs  Int      @default(0) @map("active_jobs")
  memoryUsage Float    @default(0) @map("memory_usage")
  cpuUsage    Float    @default(0) @map("cpu_usage")
  recordedAt  DateTime @default(now()) @map("recorded_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_heartbeats")
  @@index([workerId])
  @@index([recordedAt])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@index([userId])
  @@index([resource])
  @@index([createdAt])
}
